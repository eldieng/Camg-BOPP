# Configuration Base de Données
DATABASE_URL="postgresql://postgres:password@localhost:5432/camg_bopp?schema=public"

# Configuration JWT
# IMPORTANT: Générer un secret sécurisé avec: openssl rand -base64 64
JWT_SECRET="CHANGEZ_MOI_EN_PRODUCTION_utilisez_openssl_rand_base64_64"
JWT_EXPIRES_IN="24h"

# Configuration Serveur
PORT=3000
NODE_ENV=development

# Configuration CORS
CORS_ORIGIN="http://localhost:5173"

# Configuration Redis (pour production)
REDIS_URL="redis://localhost:6379"

# Configuration Sécurité
# Clé de chiffrement pour données médicales sensibles (32 bytes en base64)
# Générer avec: openssl rand -base64 32
ENCRYPTION_KEY="CHANGEZ_MOI_EN_PRODUCTION_32_bytes_base64"

# Forcer HTTPS en production
FORCE_HTTPS="false"
