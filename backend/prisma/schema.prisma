// Schéma Prisma pour CAMG-BOPP
// Système de gestion des patients et files d'attente

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ÉNUMÉRATIONS
// ============================================

enum UserRole {
  ACCUEIL
  TEST_VUE
  MEDECIN
  LUNETTES
  MEDICAMENTS
  BLOC
  PORTE
  ADMIN
}

enum Gender {
  MALE
  FEMALE
}

enum TicketStatus {
  WAITING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum Priority {
  NORMAL
  ELDERLY
  PREGNANT
  DISABLED
  EMERGENCY
}

enum Station {
  ACCUEIL
  TEST_VUE
  CONSULTATION
  LUNETTES
  MEDICAMENTS
  BLOC_OPERATOIRE
}

enum AnalysisStatus {
  PRESCRIBED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AnalysisType {
  GLYCEMIE
  TENSION_ARTERIELLE
  RADIOLOGIE
  ECHOGRAPHIE
  BILAN_SANGUIN
  NFS
  GROUPE_SANGUIN
  BIOCHIMIE
  AUTRE
}

enum SurgeryStatus {
  WAITING_ANALYSIS
  ANALYSIS_COMPLETE
  ELIGIBLE
  NOT_ELIGIBLE
  SCHEDULED
  PRE_OP
  IN_SURGERY
  POST_OP
  COMPLETED
  CANCELLED
}

enum SurgeryType {
  CATARACTE
  GLAUCOME
  PTERYGION
  STRABISME
  DECOLLEMENT_RETINE
  GREFFE_CORNEE
  LASER
  AUTRE
}

enum OperatedEye {
  OD
  OG
  LES_DEUX
}

enum GateEntryStatus {
  EXPECTED       // Patient attendu (a un RDV)
  ARRIVED        // Patient arrivé (coché par l'agent)
  SENT_TO_ACCUEIL // Envoyé à l'accueil
  REGISTERED     // Ticket créé par l'accueil
  NO_SHOW        // Patient absent
}

enum QueueStatus {
  WAITING
  CALLED
  IN_SERVICE
  COMPLETED
  SKIPPED
}

enum EyeType {
  OD
  OG
}

enum PrescriptionSource {
  INTERNAL   // Ordonnance du dispensaire
  EXTERNAL   // Ordonnance externe (autre médecin)
}

// ============================================
// MODÈLES
// ============================================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  firstName    String
  lastName     String
  role         UserRole
  assignedRoom Int?     // Salle assignée pour les médecins (1 ou 2)
  isActive     Boolean  @default(true)
  lastLogin    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  consultations Consultation[] @relation("DoctorConsultations")
  visionTests   VisionTest[]   @relation("TechnicianTests")
  surgeriesAsSurgeon Surgery[]  @relation("SurgeonSurgeries")

  @@map("users")
}

model Patient {
  id                 String   @id @default(uuid())
  registrationNumber String?  @unique // Numéro d'immatriculation unique (ex: CAMG-2026-00001), optionnel pour migration
  firstName          String
  lastName           String
  dateOfBirth        DateTime
  gender             Gender
  address            String?
  phone              String?
  emergencyContact   String?
  isPregnant         Boolean  @default(false)
  isDisabled         Boolean  @default(false)
  isVIP              Boolean  @default(false) // Patient VIP (priorité spéciale)
  vipReason          String?  // Raison du statut VIP
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tickets       Ticket[]
  visionTests   VisionTest[]
  consultations Consultation[]
  appointments  Appointment[]
  labAnalyses   LabAnalysis[]
  surgeries     Surgery[]
  gateEntries   GateEntry[]
  referrals     Referral[]
  glassesOrders GlassesOrder[]

  @@index([registrationNumber])
  @@index([lastName, firstName])
  @@index([phone])
  @@map("patients")
}

model Ticket {
  id             String       @id @default(uuid())
  ticketNumber   String       @unique
  qrCode         String       @unique
  patientId      String
  priority       Priority     @default(NORMAL)
  priorityReason String?
  status         TicketStatus @default(WAITING)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  patient    Patient     @relation(fields: [patientId], references: [id])
  queueEntry QueueEntry?

  @@index([createdAt])
  @@index([status])
  @@map("tickets")
}

model QueueEntry {
  id          String      @id @default(uuid())
  ticketId    String      @unique
  station     Station
  position    Int
  status      QueueStatus @default(WAITING)
  roomNumber  Int?        // Numéro de salle assigné (1 ou 2 pour consultation)
  calledAt    DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  ticket Ticket @relation(fields: [ticketId], references: [id])

  @@index([station, status])
  @@index([position])
  @@map("queue_entries")
}

model VisionTest {
  id           String @id @default(uuid())
  patientId    String
  technicianId String

  rightEye_sphere   Float?
  rightEye_cylinder Float?
  rightEye_axis     Int?
  rightEye_acuity   String?
  rightEye_addition Float?

  leftEye_sphere   Float?
  leftEye_cylinder Float?
  leftEye_axis     Int?
  leftEye_acuity   String?
  leftEye_addition Float?

  pupillaryDistance Float?
  notes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient    Patient @relation(fields: [patientId], references: [id])
  technician User    @relation("TechnicianTests", fields: [technicianId], references: [id])

  @@index([patientId])
  @@index([createdAt])
  @@map("vision_tests")
}

model Consultation {
  id        String @id @default(uuid())
  patientId String
  doctorId  String

  chiefComplaint        String?
  diagnosis             String?
  notes                 String?
  intraocularPressureOD Float?
  intraocularPressureOG Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient       Patient        @relation(fields: [patientId], references: [id])
  doctor        User           @relation("DoctorConsultations", fields: [doctorId], references: [id])
  prescriptions Prescription[]
  labAnalyses   LabAnalysis[]
  surgeries     Surgery[]
  referrals     Referral[]
  glassesOrders GlassesOrder[]

  @@index([patientId])
  @@index([doctorId])
  @@index([createdAt])
  @@map("consultations")
}

model Prescription {
  id             String  @id @default(uuid())
  consultationId String

  eyeType  EyeType
  sphere   Float?
  cylinder Float?
  axis     Int?
  addition Float?

  lensType String?
  coating  String?

  medication String?
  dosage     String?
  duration   String?

  source           PrescriptionSource @default(INTERNAL) // Interne ou externe
  externalDoctor   String?  // Nom du médecin externe si source = EXTERNAL
  externalClinic   String?  // Clinique/hôpital externe

  notes String?

  createdAt DateTime @default(now())

  consultation Consultation @relation(fields: [consultationId], references: [id])

  @@map("prescriptions")
}

model Appointment {
  id            String   @id @default(uuid())
  patientId     String
  scheduledDate DateTime
  scheduledTime String
  reason        String?
  status        String   @default("SCHEDULED")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  patient    Patient     @relation(fields: [patientId], references: [id])
  gateEntry  GateEntry?

  @@index([scheduledDate])
  @@index([patientId])
  @@map("appointments")
}

model GateEntry {
  id            String           @id @default(uuid())
  patientId     String?
  appointmentId String?          @unique
  firstName     String           // Pré-rempli si patient existant
  lastName      String
  phone         String?
  priority      Priority         @default(NORMAL)
  status        GateEntryStatus  @default(EXPECTED)
  arrivedAt     DateTime?
  sentAt        DateTime?        // Quand envoyé à l'accueil
  notes         String?
  isWalkIn      Boolean          @default(false) // Patient sans RDV
  date          DateTime         @default(now()) // Date du jour
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  patient     Patient?     @relation(fields: [patientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([date])
  @@index([status])
  @@index([patientId])
  @@map("gate_entries")
}

model DailyStats {
  id                    String   @id @default(uuid())
  date                  DateTime @unique
  totalPatients         Int      @default(0)
  totalTickets          Int      @default(0)
  completedTickets      Int      @default(0)
  cancelledTickets      Int      @default(0)
  avgWaitTimeMinutes    Float?
  avgServiceTimeMinutes Float?
  consultationsByDoctor Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("daily_stats")
}

// ============================================
// BLOC OPÉRATOIRE
// ============================================

model LabAnalysis {
  id               String         @id @default(uuid())
  patientId        String
  consultationId   String?
  type             AnalysisType
  customType       String?        // Si type = AUTRE
  status           AnalysisStatus @default(PRESCRIBED)
  prescribedDate   DateTime       @default(now())
  completedDate    DateTime?
  results          String?        // Résultats textuels
  resultValue      Float?         // Valeur numérique si applicable
  normalRange      String?        // Plage normale (ex: "0.7 - 1.1 g/L")
  isNormal         Boolean?       // Résultat dans la norme ?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  patient      Patient       @relation(fields: [patientId], references: [id])
  consultation Consultation? @relation(fields: [consultationId], references: [id])
  surgery      Surgery?      @relation

  @@index([patientId])
  @@index([status])
  @@index([consultationId])
  @@map("lab_analyses")
}

model Surgery {
  id               String        @id @default(uuid())
  patientId        String
  consultationId   String?
  surgeonId        String?
  type             SurgeryType
  customType       String?       // Si type = AUTRE
  operatedEye      OperatedEye?
  status           SurgeryStatus @default(WAITING_ANALYSIS)
  scheduledDate    DateTime?
  scheduledTime    String?
  actualStartTime  DateTime?
  actualEndTime    DateTime?
  anesthesiaType   String?       // Locale, générale, etc.
  diagnosis        String?       // Diagnostic pré-opératoire
  operativeNotes   String?       // Notes per-opératoires
  complications    String?       // Complications éventuelles
  consentSigned    Boolean       @default(false)
  preOpChecklist   Json?         // Check-list pré-opératoire
  analysisId       String?       @unique // Lien vers l'analyse requise
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  patient      Patient       @relation(fields: [patientId], references: [id])
  consultation Consultation? @relation(fields: [consultationId], references: [id])
  surgeon      User?         @relation("SurgeonSurgeries", fields: [surgeonId], references: [id])
  analysis     LabAnalysis?  @relation(fields: [analysisId], references: [id])
  followUps    PostOpFollowUp[]
  materials    PreOpMaterial[]

  @@index([patientId])
  @@index([status])
  @@index([scheduledDate])
  @@index([surgeonId])
  @@map("surgeries")
}

model PostOpFollowUp {
  id          String   @id @default(uuid())
  surgeryId   String
  dayNumber   Int      // J+1, J+7, J+30
  scheduledDate DateTime?
  actualDate  DateTime?
  visualAcuity String? // Acuité visuelle post-op
  intraocularPressure Float?
  woundStatus  String? // État de la cicatrice
  complications String?
  treatment    String? // Traitement prescrit
  notes        String?
  isCompleted  Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  surgery Surgery @relation(fields: [surgeryId], references: [id])

  @@index([surgeryId])
  @@index([scheduledDate])
  @@map("post_op_follow_ups")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([entity])
  @@map("audit_logs")
}

// ============================================
// ORIENTATION PATIENTS (REFERRALS)
// ============================================

enum ReferralStatus {
  PENDING      // En attente de prise en charge
  IN_PROGRESS  // Patient en cours de traitement ailleurs
  COMPLETED    // Traitement terminé
  CANCELLED    // Annulé
  LOST         // Patient perdu de vue
}

enum ReferralReason {
  SERVICE_UNAVAILABLE  // Service non disponible au dispensaire
  EQUIPMENT_MISSING    // Équipement manquant
  SPECIALIST_NEEDED    // Spécialiste requis
  EMERGENCY            // Urgence nécessitant transfert
  PATIENT_CHOICE       // Choix du patient
  OTHER                // Autre raison
}

model Referral {
  id              String         @id @default(uuid())
  patientId       String
  consultationId  String?
  referredBy      String         // ID du médecin qui oriente
  
  reason          ReferralReason
  customReason    String?        // Si reason = OTHER
  serviceNeeded   String         // Service requis (ex: "Chirurgie rétine", "IRM")
  externalClinic  String         // Nom de la structure externe
  externalDoctor  String?        // Nom du médecin externe si connu
  externalPhone   String?        // Téléphone de la structure
  externalAddress String?        // Adresse de la structure
  
  status          ReferralStatus @default(PENDING)
  referralDate    DateTime       @default(now())
  appointmentDate DateTime?      // Date du RDV externe si connu
  completedDate   DateTime?      // Date de fin de traitement
  
  diagnosis       String?        // Diagnostic initial
  treatmentNotes  String?        // Notes sur le traitement reçu ailleurs
  followUpNeeded  Boolean        @default(true) // Suivi requis au retour
  followUpDate    DateTime?      // Date de suivi prévue
  
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  patient      Patient       @relation(fields: [patientId], references: [id])
  consultation Consultation? @relation(fields: [consultationId], references: [id])

  @@index([patientId])
  @@index([status])
  @@index([reason])
  @@index([serviceNeeded])
  @@index([referralDate])
  @@map("referrals")
}

// ============================================
// BONS DE COMMANDE INTERNES
// ============================================

enum OrderStatus {
  DRAFT        // Brouillon
  SUBMITTED    // Soumis
  APPROVED     // Approuvé
  IN_PROGRESS  // En cours de traitement
  COMPLETED    // Livré
  CANCELLED    // Annulé
}

model InternalOrder {
  id            String      @id @default(uuid())
  orderNumber   String      @unique // Numéro de commande (BC-YYYY-NNNNN)
  requestedBy   String      // ID de l'utilisateur qui fait la commande
  station       Station     // Station qui fait la commande (LUNETTES, etc.)
  
  status        OrderStatus @default(DRAFT)
  priority      Priority    @default(NORMAL)
  
  requestDate   DateTime    @default(now())
  neededByDate  DateTime?   // Date limite souhaitée
  approvedDate  DateTime?
  approvedBy    String?     // ID de l'admin qui approuve
  completedDate DateTime?
  
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  items         OrderItem[]

  @@index([station])
  @@index([status])
  @@index([requestDate])
  @@map("internal_orders")
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  
  itemName    String  // Nom de l'article
  description String? // Description détaillée
  quantity    Int
  unit        String? // Unité (pièces, boîtes, etc.)
  
  notes       String?

  order InternalOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

// ============================================
// COMMANDES DE LUNETTES (ATELIER)
// ============================================

enum GlassesOrderStatus {
  PENDING       // En attente de fabrication
  IN_PROGRESS   // En cours de fabrication
  READY         // Prêt à être récupéré
  DELIVERED     // Livré au patient
  CANCELLED     // Annulé
}

model GlassesOrder {
  id              String             @id @default(uuid())
  orderNumber     String             @unique // Numéro de commande (LUN-YYYY-NNNNN)
  patientId       String
  consultationId  String
  prescriptionId  String?            // Prescription optique liée (OD ou OG)
  
  // Prescription OD (Œil Droit)
  odSphere        Float?
  odCylinder      Float?
  odAxis          Int?
  odAddition      Float?
  
  // Prescription OG (Œil Gauche)
  ogSphere        Float?
  ogCylinder      Float?
  ogAxis          Int?
  ogAddition      Float?
  
  // Détails lunettes
  lensType        String?            // Type de verre (simple, progressif, bifocal)
  coating         String?            // Traitement (anti-reflet, photochromique, etc.)
  frameType       String?            // Type de monture
  frameReference  String?            // Référence monture
  pupillaryDistance Float?           // Écart pupillaire
  
  status          GlassesOrderStatus @default(PENDING)
  priority        Priority           @default(NORMAL)
  
  orderDate       DateTime           @default(now())
  estimatedDate   DateTime?          // Date estimée de livraison
  readyDate       DateTime?          // Date de mise à disposition
  deliveredDate   DateTime?          // Date de remise au patient
  
  notes           String?
  workshopNotes   String?            // Notes de l'atelier
  
  createdBy       String             // ID utilisateur qui crée la commande
  preparedBy      String?            // ID utilisateur atelier qui prépare
  
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  patient      Patient      @relation(fields: [patientId], references: [id])
  consultation Consultation @relation(fields: [consultationId], references: [id])

  @@index([patientId])
  @@index([consultationId])
  @@index([status])
  @@index([orderDate])
  @@map("glasses_orders")
}

// ============================================
// MATÉRIEL PRÉOPÉRATOIRE
// ============================================

model PreOpMaterial {
  id          String   @id @default(uuid())
  surgeryId   String
  
  itemName    String   // Nom du matériel
  category    String?  // Catégorie (Instruments, Consommables, Implants, etc.)
  quantity    Int      @default(1)
  isAvailable Boolean  @default(false) // Disponible en stock
  isPrepared  Boolean  @default(false) // Préparé pour l'opération
  
  notes       String?
  createdAt   DateTime @default(now())

  surgery Surgery @relation(fields: [surgeryId], references: [id], onDelete: Cascade)

  @@index([surgeryId])
  @@map("pre_op_materials")
}
